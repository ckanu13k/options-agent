# Copy to `.env` for local runs. In GitHub Actions, put these in Secrets.

# Alpaca — use your PAPER keys from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_key
ALPACA_SECRET_KEY=your_paper_secret
ALPACA_PAPER=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# Optional overrides (comma-separated tickers)
# TICKER_UNIVERSE=SPY,QQQ,AAPL,NVDA

# If true, plan trades but do not submit them (useful for the first few runs)
DRY_RUN=false
